# Feature caches (large, regenerable) and local MLflow store
# NB: ignore cache/* (contents), NOT cache/ (the dir) — git won't descend into an excluded
# directory, so the re-include below only works against a contents glob.
cache/*
# ...but ship the fitted groove manifold: tiny derived stats (per-chart 5-dim radar +
# difficulty + density; no charts/audio), needed for dataset-free generation (scripts/generate.py).
!cache/radar_manifold.npz
mlflow.db

# (Generated sample/song folders under outputs/ are covered by the outputs/* whitelist above.)
/tests/fixtures/test_audio.wav

# Generated decode samples (collapsed from ~5.4k per-file entries)
cache/samples/

# scripts/generate.py default output dir (charted song folders — artifacts, not source)
/Generated/

